  "components": {
    "schemas": {
      "CreateNotificationRequest": {
        "required": [
          "message",
          "userId"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "notificationType": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FeedbackDto": {
        "required": [
          "email",
          "fullName",
          "message",
          "reason",
          "routeId",
          "tripStatusId",
          "userProfileId"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          },
          "timeSlot": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "ratingId": {
            "maximum": 5,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "userProfileId": {
            "type": "integer",
            "format": "int32"
          },
          "routeId": {
            "type": "integer",
            "format": "int32"
          },
          "tripStatusId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "FilterDto": {
        "type": "object",
        "properties": {
          "userLocation": {
            "type": "string",
            "nullable": true
          },
          "userLatitude": {
            "type": "number",
            "format": "double"
          },
          "userLongitude": {
            "type": "number",
            "format": "double"
          },
          "destination": {
            "type": "string",
            "nullable": true
          },
          "destinationLatitude": {
            "type": "number",
            "format": "double"
          },
          "destinationLongitude": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ForgotPasswordRequest": {
        "required": [
